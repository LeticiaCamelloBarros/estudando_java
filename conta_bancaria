    	this.status = true;
    	 if  (this.getTipo().equals( "CC")) {
    		this.setSaldo( s + 50 ) ;
    	}else if (this.getTipo().equals("CP")) {
    		this.setSaldo( s + 150);
    	}
    }
    public void fecharconta(){
    	if (this.getSaldo() == 0 ){
    		//não pode se atribuir ou comparar ao um get atributo.
    	this.setStatus(false) ;
    	//para fechar uma conta ela deve estar vazia , ela não pode nem ter dinheiro , nem tá no negativo
    	}else {
    		//abre else 
    	    if (this.getSaldo()<0) 
    	    {
	    		System.out.println("pague suas dividas para fechar sua conta !!");
    	    }
    	    else if (this.getSaldo()>0) 
    	    {
    	    	System.out.println("essa conta ainda tem dinheiro,transfira todo seu montante para outra conta antes de fecha-la");
    	    }
    	}
      }
    
    	
    
    public void depositar (int v) {
    	this.setSaldo(this.getSaldo() + v) ;
    }
    public void  sacar (int v) {
      if (v<=this.getSaldo()) {
    	  if (v==this.getSaldo()) {
        	  this.setSaldo(this.getSaldo() - v);
        	  System.out.println("conta zerada");
    	  }
    	  this.setSaldo(this.getSaldo() - v);
    	  }else {
    		  System.out.println("valor que você quer sacar é maior que o seu saldo atual");
    	  }
    	  

    }
    public void pagarMensalidade() {
    	if (this.getTipo().equals("CC")) {
    		this.setSaldo(this.saldo - 12)  ;
    	}else if  (this.getTipo().equals("CP")){
    		this.setSaldo( this.saldo -15);
    	}
    }
    public int getNumconta() {
    	return this.numconta;
    }
    public void setNumconta(int n) {
    	this.numconta = n ;
    }
}
