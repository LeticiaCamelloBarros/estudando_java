    	if (this.getTipo() ==null) {
    		System.out.println("vc deve configurar um tipo de conta antes do tentar configurar o saldo");
    	}
        this.saldo = s ; 
    }
    public String getDono (){
    	return this.dono;
    }
    public void Setdono (String d ) {
    	this.dono = d ;
    }
    public boolean getStatus() {
         return this.status ;
    }
