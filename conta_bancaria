package megapacote;

public class Conta_banco {
    private int saldo ;
    private int numconta;
    private String tipo ;
    private boolean status ;
    private String dono ;
    public Conta_banco () {
    	this.status = false ;
    	this.saldo = 0 ;
    }
    public String getTipo() {
    	return this.tipo;
    }
    public void setTipo(String t) {
    	if (t.equals("CC") || t.equals("CP")) {
    		this.tipo = t ;
    	}else {
    		System.out.println("tipo de conta inválido");
    	}
    }
    public int getSaldo() {
    	return this.saldo;
    }
